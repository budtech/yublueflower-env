#!/bin/bash
[[ ! -x "$0" ]] && chmod +x "$0"

export LC_ALL=C

function yublueflower_banner() {
    echo -e "\033[36m"
    echo "Version       : xast v0.0.1 (latest)"
    echo "Architecture  : $(lsb_release -ds) ($(uname -m))"
    echo "Time          : $(date '+%Y-%m-%d %H:%M:%S')"
    echo "Uptime        : $(uptime -p | sed 's/up //')"
    echo -e "\033[0m"
    echo ""
}

function yublueflower_env() {
    xast="$HOME/.local/bin/xast"
    path=$(realpath "$0")
    [[ "$path" != "$xast" ]] && mkdir -p "$HOME/.local/bin" && cp "$path" "$xast" && chmod +x "$xast"

    if ! grep -q "export PATH=\$HOME/.local/bin:\$PATH" ~/.profile; then
        echo "export PATH=\$HOME/.local/bin:\$PATH" >> ~/.profile
    fi
}

function yublueflower_help() {
    echo -e "\033[36mUsage:\033[0m"
    echo "xast --url http://testphp.vulnweb.com"
    echo ""
    echo -e "\033[36mOptions:\033[0m"
    echo "--help                    Show help message"
    echo "--live-session string[]   Use --live-session to pass session (e.g., --live-session \"Cookie: laravel_session=...; XSRF-TOKEN=...\")"
    echo "--web-archives            Use --web-archives to time travel assets"
    echo "--silent                  Keep crawl URL logs behaved"
    echo "--extended-workflows      Use --extended-workflows to get high Bug Bounty rewards"
}

function yublueflower_URLs_log() {
    [[ "$silent" == "--silent" ]] && cat >> "$yublueflower_URLs_raw" || tee -a "$yublueflower_URLs_raw"
}

function yublueflower_EXTs_log() {
    [[ "$silent" == "--silent" ]] && cat >> "$yublueflower_EXTs_raw" || tee -a "$yublueflower_EXTs_raw"
}

function yublueflower_workflow() {
    yublueflower_banner
    local url="" web_archives="" extended_workflows="" silent=""
    local -a live_session=()
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --url)
                if [[ -n "$2" && "$2" != -* ]]; then
                    url="$2"
                    shift 2
                else
                    echo -e "\033[31m[!] Missing URL after --url. Use --help for usage instructions\033[0m"
                    exit 1
                fi
                ;;
            --web-archives)
                web_archives="--web-archives"
                shift;;
            --silent)
                silent="--silent"
                shift;;
            --extended-workflows)
                extended_workflows="--extended-workflows"
                shift;;
            --live-session)
                shift
                header=""
                while [[ "$1" != --* && -n "$1" ]]; do
                    header+="$1 "
                    shift
                done
                header="${header%" "}"
                if [[ -n "$header" ]]; then
                    live_session+=("$header")
                else
                    echo -e "\033[31m[!] Missing header after --live-session. Use --help for usage instructions\033[0m"
                    exit 1
                fi
                ;;
            *)
                echo -e "\033[31m[!] Unrecognized argument: $1. Use --help for usage instructions\033[0m"
                exit 1;;
        esac
    done

    if [[ -z "$url" ]]; then
        echo -e "\033[31m[!] Missing required --url argument. Use --help for usage instructions\033[0m"
        exit 1
    fi

    local yublueflower_home="$HOME/yublueflower-cli/xast"
    local wrkd="xast_$(date '+%Y%m%d_%H%M%S')"
    local wrkp="$yublueflower_home/$wrkd"
    mkdir -p "$yublueflower_home"
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo "Testing started at $timestamp"

    if ! [[ "$url" =~ ^https?:// ]]; then
        echo -e "\033[31m[!] Please include http:// or https://. Use --help for usage instructions\033[0m"
        exit 1
    fi

    domain=$(echo "$url" | sed -E 's|https?://||' | cut -d'/' -f1)
    timestamp=$(date "+%Y%m%d%H%M%S")
    yublueflower_URLs_raw="/tmp/yublueflower_URLs_raw_$timestamp.txt"    
    yublueflower_URLs_tmp="/tmp/yublueflower_URLs_tmp_$timestamp.txt"
    yublueflower_URLs_wrk="/tmp/yublueflower_URLs_wrk_$timestamp.txt"
    > "$yublueflower_URLs_raw"

    yublueflower_EXTs_raw="/tmp/yublueflower_EXTs_raw_$timestamp.txt"    
    yublueflower_EXTs_tmp="/tmp/yublueflower_EXTs_tmp_$timestamp.txt"
    yublueflower_EXTs_wrk="/tmp/yublueflower_EXTs_wrk_$timestamp.txt"
    > "$yublueflower_EXTs_raw"
    
    yublueflower_EXTs_regex='\.(jpg|jpeg|png|gif|svg|ico|css|js|woff2?|ttf|eot|pdf|zip|tar|gz|rar|mp4|mp3|docx?|xlsx?|pptx?|exe|apk|json|xml|csv)(\?|$)'

    yublueflower_KEYs_regex='(\?|&)(utm_(source|medium|campaign|term|content)|fbclid|gclid|yclid|msclkid|ga(_cid|id)?|mc_(cid|eid)|_hs(enc|mi)?|ref(_src|_url|id)?|src|source(Name)?|from|via|tracking|track(id)?|click|ad(id|group(id)?)?|pixel|campaignid|theme|style|layout|format|viewtype|preview|width|height|nocache|noload|cache|ver(sion)?|ts|timestamp|_|cb|rnd|client|browser|device|screen|dpi|env|platform|debug|log|tab|offset|start(index)?|step|scroll|position|expand|collapse|open|closed|show)='

    if [[ "$web_archives" != "--web-archives" ]]; then
        katana -u "$url" -match-regex '.*\?.*=.*' -silent |
        perl -pe 's/[^[:print:]\t\r\n]//g' |
        grep -E "^${url%/}(/|$)" |
        grep -Ev "$yublueflower_EXTs_regex" |
        grep -Ev "$yublueflower_KEYs_regex" |
        awk -F'?' '
        $2{
            out=$1"?"

            delete seenk

            n=split($2,a,"&")

            for(i=1;i<=n;i++){
                split(a[i],b,"=")

                if(b[1]!="" && !seenk[b[1]]++){
                    out=(out==($1"?") ? out : out"&") b[1]"=yublueflower"
                }
            }

            if(out!=($1"?"))
                print out
        }' |
        grep -Ev 'https?://[^ ]+https?://' |
        grep -Ev '[?&][^=]*[^a-zA-Z0-9_.-][^=]*=' |
        cut -d' ' -f1 |
        awk -F'?' '
        {
            path=$1

            gsub(/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}/,":uuid",path)

            nseg=split(path,seg,"/")
            path=""

            for(i=1;i<=nseg;i++){

                if(seg[i] ~ /^[0-9a-fA-F]{16,}$/)
                    seg[i]=":rid"
                else if(length(seg[i]) >= 12 &&
                        seg[i] ~ /^[A-Za-z0-9_-]+$/ &&
                        seg[i] ~ /[A-Za-z]/ &&
                        seg[i] ~ /[0-9]/)
                    seg[i]=":rid"

                path = (path=="" ? seg[i] : path"/"seg[i])
            }

            gsub(/[0-9]+/,":id",path)

            while(gsub(/:id[-_\.\/]:id/,":id",path));

            sig=path

            if($2){

                delete keys
                delete ordered
                c=0

                n=split($2,p,"&")

                for(i=1;i<=n;i++){
                    split(p[i],kv,"=")
                    if(kv[1]!="" && !keys[kv[1]]++)
                        ordered[++c]=kv[1]
                }

                for(i=1;i<=c;i++){
                    for(j=i+1;j<=c;j++){
                        if(ordered[i] > ordered[j]){
                            tmp=ordered[i]
                            ordered[i]=ordered[j]
                            ordered[j]=tmp
                        }
                    }
                }

                for(i=1;i<=c;i++)
                    sig=sig"&"ordered[i]
            }

            if(!seen[sig]++)
                print

            c=0
        }' | yublueflower_URLs_log | while read -r line; do
            echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
        done

        if [[ "$extended_workflows" == "--extended-workflows" ]]; then
            katana -u "$url" -silent |
            grep -E "^${url%/}(/|$)" |
            grep -Ei '\.(env|git|json|js|yml|yaml)(\?|$)' |
            sed -E 's/(\.env|\.git|\.json|\.js|\.yml|\.yaml).*/\1/' |
            sort -u |
            httpx -match-code 200 -silent |
            yublueflower_EXTs_log | while read -r line; do
                echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
            done
        fi
    else
        urlfinder -d "$domain" -silent |
        perl -pe 's/[^[:print:]\t\r\n]//g' |
        grep -E "^${url%/}(/|$)" |
        grep "\?.*=" |
        grep -Ev "$yublueflower_EXTs_regex" |
        grep -Ev "$yublueflower_KEYs_regex" |
        awk -F'?' '
        $2{
            out=$1"?"

            delete seenk

            n=split($2,a,"&")

            for(i=1;i<=n;i++){
                split(a[i],b,"=")

                if(b[1]!="" && !seenk[b[1]]++){
                    out=(out==($1"?") ? out : out"&") b[1]"=yublueflower"
                }
            }

            if(out!=($1"?"))
                print out
        }' |
        grep -Ev 'https?://[^ ]+https?://' |
        grep -Ev '[?&][^=]*[^a-zA-Z0-9_.-][^=]*=' |
        cut -d' ' -f1 |
        awk -F'?' '
        {
            path=$1

            gsub(/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}/,":uuid",path)

            nseg=split(path,seg,"/")
            path=""

            for(i=1;i<=nseg;i++){

                if(seg[i] ~ /^[0-9a-fA-F]{16,}$/)
                    seg[i]=":rid"
                else if(length(seg[i]) >= 12 &&
                        seg[i] ~ /^[A-Za-z0-9_-]+$/ &&
                        seg[i] ~ /[A-Za-z]/ &&
                        seg[i] ~ /[0-9]/)
                    seg[i]=":rid"

                path = (path=="" ? seg[i] : path"/"seg[i])
            }

            gsub(/[0-9]+/,":id",path)

            while(gsub(/:id[-_\.\/]:id/,":id",path));

            sig=path

            if($2){

                delete keys
                delete ordered
                c=0

                n=split($2,p,"&")

                for(i=1;i<=n;i++){
                    split(p[i],kv,"=")
                    if(kv[1]!="" && !keys[kv[1]]++)
                        ordered[++c]=kv[1]
                }

                for(i=1;i<=c;i++){
                    for(j=i+1;j<=c;j++){
                        if(ordered[i] > ordered[j]){
                            tmp=ordered[i]
                            ordered[i]=ordered[j]
                            ordered[j]=tmp
                        }
                    }
                }

                for(i=1;i<=c;i++)
                    sig=sig"&"ordered[i]
            }

            if(!seen[sig]++)
                print

            c=0
        }' | yublueflower_URLs_log | while read -r line; do
            echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
        done

        if [[ "$extended_workflows" == "--extended-workflows" ]]; then
            urlfinder -d "$domain" -silent |
            perl -pe 's/[^[:print:]\t\r\n]//g' |
            grep -E "^${url%/}(/|$)" |
            grep -Ei '\.(env|git|json|js|yml|yaml)(\?|$)' |
            sed -E 's/(\.env|\.git|\.json|\.js|\.yml|\.yaml).*/\1/' |
            sort -u |
            httpx -match-code 200 -silent |
            yublueflower_EXTs_log | while read -r line; do
                echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
            done

            katana -u "$url" -match-regex '.*\?.*=.*' -silent |
            perl -pe 's/[^[:print:]\t\r\n]//g' |
            grep -E "^${url%/}(/|$)" |
            grep -Ev "$yublueflower_EXTs_regex" |
            grep -Ev "$yublueflower_KEYs_regex" |
            awk -F'?' '
            $2{
                out=$1"?"

                delete seenk

                n=split($2,a,"&")

                for(i=1;i<=n;i++){
                    split(a[i],b,"=")

                    if(b[1]!="" && !seenk[b[1]]++){
                        out=(out==($1"?") ? out : out"&") b[1]"=yublueflower"
                    }
                }

                if(out!=($1"?"))
                    print out
            }' |
            grep -Ev 'https?://[^ ]+https?://' |
            grep -Ev '[?&][^=]*[^a-zA-Z0-9_.-][^=]*=' |
            cut -d' ' -f1 |
            awk -F'?' '
            {
                path=$1

                gsub(/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}/,":uuid",path)

                nseg=split(path,seg,"/")
                path=""

                for(i=1;i<=nseg;i++){

                    if(seg[i] ~ /^[0-9a-fA-F]{16,}$/)
                        seg[i]=":rid"
                    else if(length(seg[i]) >= 12 &&
                            seg[i] ~ /^[A-Za-z0-9_-]+$/ &&
                            seg[i] ~ /[A-Za-z]/ &&
                            seg[i] ~ /[0-9]/)
                        seg[i]=":rid"

                    path = (path=="" ? seg[i] : path"/"seg[i])
                }

                gsub(/[0-9]+/,":id",path)

                while(gsub(/:id[-_\.\/]:id/,":id",path));

                sig=path

                if($2){

                    delete keys
                    delete ordered
                    c=0

                    n=split($2,p,"&")

                    for(i=1;i<=n;i++){
                        split(p[i],kv,"=")
                        if(kv[1]!="" && !keys[kv[1]]++)
                            ordered[++c]=kv[1]
                    }

                    for(i=1;i<=c;i++){
                        for(j=i+1;j<=c;j++){
                            if(ordered[i] > ordered[j]){
                                tmp=ordered[i]
                                ordered[i]=ordered[j]
                                ordered[j]=tmp
                            }
                        }
                    }

                    for(i=1;i<=c;i++)
                        sig=sig"&"ordered[i]
                }

                if(!seen[sig]++)
                    print

                c=0
            }' | yublueflower_URLs_log | while read -r line; do
                echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
            done

            katana -u "$url" -silent |
            grep -E "^${url%/}(/|$)" |
            grep -Ei '\.(env|git|json|js|yml|yaml)(\?|$)' |
            sed -E 's/(\.env|\.git|\.json|\.js|\.yml|\.yaml).*/\1/' |
            sort -u |
            httpx -match-code 200 -silent |
            yublueflower_EXTs_log | while read -r line; do
                echo -e "[\e[36m$(date '+%Y-%m-%d %H:%M:%S')\e[0m] $line"
            done
        fi
    fi

    tee -a "$yublueflower_URLs_tmp" < "$yublueflower_URLs_raw" > /dev/null && awk -F'[?]' '!seen[$1]++' "$yublueflower_URLs_tmp" | sort -u | tee "$yublueflower_URLs_wrk" > /dev/null && tee "$yublueflower_URLs_tmp" < "$yublueflower_URLs_wrk" > /dev/null
    tee -a "$yublueflower_EXTs_tmp" < "$yublueflower_EXTs_raw" > /dev/null && awk -F'[?]' '!seen[$1]++' "$yublueflower_EXTs_tmp" | sort -u | tee "$yublueflower_EXTs_wrk" > /dev/null && tee "$yublueflower_EXTs_tmp" < "$yublueflower_EXTs_wrk" > /dev/null

    rm -rf "$yublueflower_URLs_raw" "$yublueflower_URLs_tmp"
    rm -rf "$yublueflower_EXTs_raw" "$yublueflower_EXTs_tmp"
    
    rraw=()
    for h in "${live_session[@]}"; do
        rraw+=("-header" "$h")
    done

    yublueflower_RSTs_raw="/tmp/yublueflower_RSTs_raw_$timestamp.txt"
    yublueflower_RSTs_wrk="/tmp/yublueflower_RSTs_wrk_$timestamp.txt"
    > "$yublueflower_RSTs_raw"

    if [[ "$extended_workflows" != "--extended-workflows" ]]; then
        nuclei -u "$url" -timestamp "${rraw[@]}" -silent -markdown-export "$wrkp" | tee -a "$yublueflower_RSTs_raw"
        xargs -a "$yublueflower_URLs_wrk" -I {} -P 5 nuclei -u {} -timestamp -dast -silent -markdown-export "$wrkp" | tee -a "$yublueflower_RSTs_raw"
    else
        nuclei -u "$url" -timestamp "${rraw[@]}" -silent -markdown-export "$wrkp" | tee -a "$yublueflower_RSTs_raw"
        xargs -a "$yublueflower_URLs_wrk" -I {} -P 5 nuclei -u {} -timestamp -dast -fa high -silent -markdown-export "$wrkp" | tee -a "$yublueflower_RSTs_raw"
        xargs -a "$yublueflower_EXTs_wrk" -I {} -P 5 nuclei -u {} -timestamp -tags exposure -silent -markdown-export "$wrkp" | tee -a "$yublueflower_RSTs_raw"
    fi

    perl -pe 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$yublueflower_RSTs_raw" | tee "$yublueflower_RSTs_wrk" > /dev/null
    p1=0; p2=0; p3=0; p4=0; p5=0; unknown=0
    while IFS= read -r line; do
        case "$line" in
            *"[critical]"*) ((p1++));;
            *"[high]"*)     ((p2++));;
            *"[medium]"*)   ((p3++));;
            *"[low]"*)      ((p4++));;
            *"[info]"*)     ((p5++));;
            *"[unknown]"*)  ((unknown++));;
        esac
    done < "$yublueflower_RSTs_wrk"

    echo -e "\033[36m🧠 Priority P1–P5\033[0m"
    echo "Bug Bounty rewards await, P1 is bounty, P5 is trivia"
    echo -e "P1: Critical      → $p1"
    echo -e "P2: High          → $p2"
    echo -e "P3: Medium        → $p3"
    echo -e "P4: Low           → $p4"
    echo -e "P5: Informational → $p5"
    echo -e "Unknown           → $unknown"
    echo -e "[\033[36m$(date '+%Y-%m-%d %H:%M:%S')\033[0m] Write-up path \033[36mglow $yublueflower_home/$wrkd\033[0m — security issues await"
    [[ -f "$wrkp/index.md" ]] && rm -rf "$wrkp/index.md"
    echo "Testing finished at $(date "+%Y-%m-%d %H:%M:%S")"
    rm -rf "$yublueflower_RSTs_raw"

    rm -rf "$yublueflower_URLs_wrk"
    rm -rf "$yublueflower_EXTs_wrk"
    rm -rf "$yublueflower_RSTs_wrk"
}

if [[ -n $1 && $1 != --help ]]; then
    yublueflower_workflow "$@"
else
    [[ -z $1 ]] && yublueflower_env
    yublueflower_banner; yublueflower_help
    [[ -z $1 ]] && exec bash -l
    exit 0
fi
