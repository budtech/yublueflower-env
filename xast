    echo -e "[\033[36m$(date '+%Y-%m-%d %H:%M:%S')\033[0m] Write-up path \033[36mglow $yublueflower_home/$wrkd\033[0m — security issues await"
    [[ -f "$wrkp/index.md" ]] && unlink "$wrkp/index.md"
    yublueflower_report_fallback
    echo "Testing finished at $(date "+%Y-%m-%d %H:%M:%S")"
}

if [[ -n $1 && $1 != --help ]]; then
    yublueflower_workflow "$@"
else
    [[ -z $1 ]] && yublueflower_env
    yublueflower_banner; yublueflower_help
    [[ -z $1 ]] && exec bash -l
    exit 0
fi
