#!/bin/bash
[[ ! -x "$0" ]] && chmod +x "$0"

export LC_ALL=C

function yublueflower_banner() {
    echo -e "\033[36m"
    echo "Version       : vscn v0.0.1 (latest)"
    echo "Architecture  : $(lsb_release -ds) ($(uname -m))"
    echo "Time          : $(date '+%Y-%m-%d %H:%M:%S')"
    echo "Uptime        : $(uptime -p | sed 's/up //')"
    echo -e "\033[0m"
    echo ""
}

function yublueflower_env() {
    vscn="$HOME/.local/bin/vscn"
    path=$(realpath "$0")
    [[ "$path" != "$vscn" ]] && mkdir -p "$HOME/.local/bin" && cp "$path" "$vscn" && chmod +x "$vscn"

    if ! grep -q "export PATH=\$HOME/.local/bin:\$PATH" ~/.profile; then
        echo "export PATH=\$HOME/.local/bin:\$PATH" >> ~/.profile
    fi
}

function yublueflower_help() {
    echo -e "\033[36mUsage:\033[0m"
    echo "vscn --url http://testphp.vulnweb.com"
    echo ""
    echo -e "\033[36mOptions:\033[0m"
    echo "--help                    Show help message"
}

function yublueflower_cleanup() {
    local file
    for file in "$yublueflower_1337pwnd_raw" "$yublueflower_1337pwnd_wrk"; do
        [[ -n "$file" && -e "$file" ]] && unlink "$file"
    done
    return 0
}

function yublueflower_stage() {
    local stage="$1"
    local stage_ts
    stage_ts=$(date '+%Y-%m-%d %H:%M:%S')
    [[ -n "$yublueflower_stage_file" ]] && printf '%s\n' "$stage" > "$yublueflower_stage_file"
    [[ -n "$yublueflower_stage_log" ]] && printf '[%s] %s\n' "$stage_ts" "$stage" >> "$yublueflower_stage_log"
    echo -e "[\033[36m$stage_ts\033[0m] Stage: $stage"
}

function yublueflower_report_fallback() {
    local report_file
    if ! compgen -G "$wrkp/*.md" > /dev/null; then
        report_file="$wrkp/target-did-not-respond.md"
        {
            echo "# Target Did Not Respond"
            echo ""
            echo "The target did not respond within the expected time frame during testing."
            echo ""
            echo "As a result, the scan could not be completed."
            echo ""
            echo "Possible causes include connectivity issues, service unavailability, traffic filtering, rate limiting, or temporary infrastructure unavailability."
        } > "$report_file"
    fi
}

function yublueflower_workflow() {
    yublueflower_banner
    local url=""
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --url)
                if [[ -n "$2" && "$2" != -* ]]; then
                    url="$2"
                    shift 2
                else
                    echo -e "\033[31m[!] Missing URL after --url. Use --help for usage instructions\033[0m"
                    exit 1
                fi
                ;;
            *)
                echo -e "\033[31m[!] Unrecognized argument: $1. Use --help for usage instructions\033[0m"
                exit 1;;
        esac
    done

    if [[ -z "$url" ]]; then
        echo -e "\033[31m[!] Missing required --url argument. Use --help for usage instructions\033[0m"
        exit 1
    fi

    local yublueflower_home="$HOME/yublueflower-cli/vscn"
    mkdir -p "$yublueflower_home"
    local wrkp
    wrkp=$(mktemp -d "$yublueflower_home/vscn_$(date '+%Y%m%d_%H%M%S')_XXXXXX_mktemp")
    local wrkd
    wrkd=$(basename "$wrkp")
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo "Testing started at $timestamp"

    if ! [[ "$url" =~ ^https?:// ]]; then
        echo -e "\033[31m[!] Please include http:// or https://. Use --help for usage instructions\033[0m"
        exit 1
    fi

    timestamp=$(date "+%Y%m%d%H%M%S")

    yublueflower_state_dir=$(mktemp -d "/tmp/vscn_$(date '+%Y%m%d_%H%M%S')_XXXXXX_mktemp")
    yublueflower_stage_file="$yublueflower_state_dir/current-stage.txt"
    yublueflower_stage_log="$yublueflower_state_dir/stage.log"
    yublueflower_1337pwnd_raw=$(mktemp "/tmp/yublueflower_1337pwnd_raw_${timestamp}_XXXXXX_mktemp.txt")
    yublueflower_1337pwnd_wrk=$(mktemp "/tmp/yublueflower_1337pwnd_wrk_${timestamp}_XXXXXX_mktemp.txt")
    trap yublueflower_cleanup EXIT
    trap 'yublueflower_cleanup; exit 130' INT
    trap 'yublueflower_cleanup; exit 143' TERM

    yublueflower_stage "scanning"
    for pwnd in info unknown; do
        timeout -k 5s 10m nuclei -u "$url" \
            -s "$pwnd" \
            -timestamp \
            -headless \
            -c 50 \
            -silent \
            -markdown-export "$wrkp"
    done | tee -a "$yublueflower_1337pwnd_raw"

    yublueflower_stage "vulnerability assessment"
    for pwnd in low medium high critical; do
        timeout -k 5s 10m nuclei -u "$url" \
            -s "$pwnd" \
            -timestamp \
            -headless \
            -c 50 \
            -silent \
            -markdown-export "$wrkp"
    done | tee -a "$yublueflower_1337pwnd_raw"

    yublueflower_stage "reporting"
    perl -pe 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$yublueflower_1337pwnd_raw" | tee "$yublueflower_1337pwnd_wrk" > /dev/null
    p1=0; p2=0; p3=0; p4=0; p5=0; unknown=0
    while IFS= read -r line; do
        case "$line" in
            *"[critical]"*) ((p1++));;
            *"[high]"*)     ((p2++));;
            *"[medium]"*)   ((p3++));;
            *"[low]"*)      ((p4++));;
            *"[info]"*)     ((p5++));;
            *"[unknown]"*)  ((unknown++));;
        esac
    done < "$yublueflower_1337pwnd_wrk"

    echo -e "\033[36m🧠 Priority P1–P5\033[0m"
    echo "Bug Bounty rewards await, P1 is bounty, P5 is trivia"
    echo -e "P1: Critical      → $p1"
    echo -e "P2: High          → $p2"
    echo -e "P3: Medium        → $p3"
    echo -e "P4: Low           → $p4"
    echo -e "P5: Informational → $p5"
    echo -e "Unknown           → $unknown"
    echo -e "[\033[36m$(date '+%Y-%m-%d %H:%M:%S')\033[0m] Write-up path \033[36mglow $yublueflower_home/$wrkd\033[0m — security issues await"
    [[ -f "$wrkp/index.md" ]] && unlink "$wrkp/index.md"
    yublueflower_report_fallback
    echo "Testing finished at $(date "+%Y-%m-%d %H:%M:%S")"
}

if [[ -n $1 && $1 != --help ]]; then
    yublueflower_workflow "$@"
else
    [[ -z $1 ]] && yublueflower_env
    yublueflower_banner; yublueflower_help
    [[ -z $1 ]] && exec bash -l
    exit 0
fi
